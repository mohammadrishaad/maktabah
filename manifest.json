{
  "name": "Maktabah",
  "short_name": "Maktabah",
  "description": "Personal Islamic study library: searchable book PDFs, study tracker, notes, and aqwal.",
  "id": "./",
  "start_url": ".",
  "scope": ".",
  "display": "standalone",
  "share_target": {
    "action": "./share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        { "name": "pdfs", "accept": ["application/pdf", "application/octet-stream", ".pdf"] }
      ]
    }
  },
  "background_color": "#0f0f11",
  "theme_color": "#0f0f11",
  "icons": [
    { "src": "icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ]
}
